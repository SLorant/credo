    padding: 4rem 3rem;
    position: relative;
    z-index: 30;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    line-height: 1.8;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 3rem;
    font-weight: 700;
    text-align: center;
  }

  h2 {
    font-size: 2rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  section {
    margin-bottom: 2rem;
  }

  p {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  ul {
    margin-left: 2rem;
    margin-bottom: 1rem;
  }

  li {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  strong {
    font-weight: 600;
    color: #ffffff;
  }

  .cookie-settings-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 4rem;
    margin-bottom: 2rem;
  }

  .cookie-settings-btn {
    background: #dbe120;
    color: black;
    border: none;
    padding: 1rem 2rem;
    font-size: 1.1rem;
    font-family: "AktivGrotesk Medium";
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cookie-settings-btn:hover {
    transform: scale(1.03);
  }

  .cookie-settings-btn:active {
    transform: translateY(0);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .privacy-policy {
      padding: 3rem 3rem;
      margin-top: 50px;
    }

    h1 {
      font-size: 2rem;
      margin-bottom: 2rem;
    }

    h2 {
      font-size: 1.5rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }
    h3 {
      font-size: 1rem;
    }

    p,
    li {
      font-size: 1rem;
    }

    ul {
      margin-left: 1.5rem;
    }

    .cookie-settings-btn {
      padding: 0.875rem 1.5rem;
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .privacy-policy {
      padding: 2rem 1.5rem;
    }

    h1 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
    }

    h2 {
      font-size: 1.1rem;
      margin-top: 1.5rem;
    }

    p,
    li {
      font-size: 0.8rem;
    }

    ul {
      margin-left: 1rem;
    }

    .cookie-settings-btn {
      padding: 0.75rem 1.25rem;
      font-size: 0.9rem;
    }
  }
</style>
